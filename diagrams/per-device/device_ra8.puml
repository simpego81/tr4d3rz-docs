@startuml TR4D3RZ_ra8
!include <archimate/Archimate>

skinparam backgroundColor #8080f1
skinparam defaultFontName "Courier New"
skinparam defaultFontColor #201d1d
skinparam defaultFontSize 11
skinparam ArrowColor #000000
skinparam packageBorderColor #444466
skinparam packageBackgroundColor #7e7e9c
skinparam packageFontColor #cccccc
skinparam packageFontSize 12
skinparam packageFontStyle bold
skinparam nodeBorderColor #556688
skinparam noteBorderColor #556688
skinparam noteBackgroundColor #585f68
skinparam noteFontColor #aaaaaa
scale 1.5

title TR4D3RZ — Device View: Renesas RA8 · (Cortex-M85)\nArchiMate Architecture v2.0  |  2026-05-12

package "Motivation Layer" <<rectangle>> {
  Motivation_Goal(goal_distribute, "Distributed Heterogeneous\nComputation")
  Motivation_Goal(goal_evolve, "Evolve Trading\nStrategies Autonomously")
  Motivation_Principle(prin_async, "Asynchronous Distributed\nEcology (no global sync)")
}

package "Business Layer" <<rectangle>> {
  Business_Process(proc_evolution, "Evolutionary Process\n(Genome → FSM → Fitness)")
  Business_Service(svc_prediction, "Prediction Service\n(daily investment signals)")
}

package "Application Layer" <<rectangle>> {
  package "Optimization Nodes  [ESP8266 · STM32F107 · STM32F3]" <<Cloud>> {
    Application_Service(opt_svc, "Optimization Service")
    Application_Component(opt_tuning, "Parameter Tuning\n(micro-optimization)")
    Application_Component(opt_validation, "Micro Validation\n(local fitness check)")
    Application_Component(opt_local, "Local Optimizer\n(offline genome tuning)")
    Application_Component(opt_capsule, "Capsule Manager\n(CBOR I/O · UART/USB)")
  }
  package "Genome Capsule System  [tr4d3rz-embedded]" <<Frame>> {
    Application_Component(capsule_mgr,  "Genome Capsule Manager\n(task packages · compressed datasets\n· deferred results)")
    Application_Component(capsule_cbor, "CBOR Serializer\n(embedded-safe · no_std)")
  }
}

package "Data Objects" <<rectangle>> {
  Business_Object(data_genome, "Hybrid Graph Genome\n(CBOR · L-System generated)")
  Business_Object(data_capsule, "Genome Capsule\n(CBOR file · offline sync)")
}

package "Technology Layer" <<rectangle>> {
  package "Medium Performance Nodes" <<Node>> {
    Technology_Device(hw_ra8, "Renesas RA8\n(Cortex-M85)")
  }
  package "Infrastructure" <<rectangle>> {
    Technology_SystemSoftware(rt_rust, "Rust Runtime\n(tr4d3rz-core · evolution · messaging)")
    Technology_SystemSoftware(rt_cbor, "CBOR Serialization\n(embedded · no_std · FlatBuffers alt.)")
    Technology_Service(net_uart, "UART Service\n(serial · CBOR framing)")
    Technology_Service(net_usb, "USB/Filesystem Service\n(capsule exchange)")
  }
  package "Storage" <<rectangle>> {
    Technology_Artifact(capsule_fs, "Genome Capsule Files\n(CBOR binary · offline sync)")
  }
}

' ── Relations ──────────────────────────────────────────────
Rel_Realization_Up(proc_evolution, goal_evolve)
Rel_Influence_Up(prin_async, goal_distribute)
Rel_Realization_Up(opt_svc, proc_evolution)
Rel_Serving_Up(opt_svc, svc_prediction)
Rel_Composition_Down(opt_svc, opt_tuning)
Rel_Composition_Down(opt_svc, opt_validation)
Rel_Composition_Down(opt_svc, opt_local)
Rel_Composition_Down(opt_svc, opt_capsule)
Rel_Assignment_Down(opt_svc, hw_ra8)
Rel_Realization_Up(rt_rust, opt_svc)
Rel_Realization_Up(rt_cbor, capsule_cbor)
Rel_Access_Up(opt_svc, capsule_fs)
Rel_Access_Up(capsule_mgr, data_capsule, "exchanges offline UART/USB")

@enduml