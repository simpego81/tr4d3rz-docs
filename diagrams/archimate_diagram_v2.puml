@startuml TR4D3RZ_Distributed_Evolutionary_System_v2
!include <archimate/Archimate>

skinparam backgroundColor #1a1a2e
skinparam defaultFontName "Courier New"
skinparam defaultFontColor #e0e0e0
skinparam defaultFontSize 11
skinparam ArrowColor #888888
skinparam packageBorderColor #444466
skinparam packageBackgroundColor #0d0d1a
skinparam packageFontColor #cccccc
skinparam packageFontSize 12
skinparam packageFontStyle bold
skinparam nodeBorderColor #556688
skinparam noteBorderColor #556688
skinparam noteBackgroundColor #0d1520
skinparam noteFontColor #aaaaaa
scale 1.5

title TR4D3RZ — Distributed Evolutionary Signal Ecology System\nArchiMate Architecture v2.0  |  2026-05-12

' ============================================================
' MOTIVATION LAYER
' ============================================================

package "Motivation Layer" <<rectangle>> {

  Motivation_Goal(goal_predict,    "Discover Predictive\nPatterns")
  Motivation_Goal(goal_evolve,     "Evolve Trading\nStrategies Autonomously")
  Motivation_Goal(goal_distribute, "Distributed Heterogeneous\nComputation")
  Motivation_Goal(goal_observe,    "Full Ecosystem\nObservability")

  Motivation_Principle(prin_openended,  "Open-Ended Evolution\n(no rigid structural limits)")
  Motivation_Principle(prin_async,      "Asynchronous Distributed\nEcology (no global sync)")
  Motivation_Principle(prin_niche,      "Emergent Niche\nSpecialization")
  Motivation_Principle(prin_coop,       "Cooperative Signaling\n(events, not references)")
  Motivation_Principle(prin_replay,     "Distributed Observability\n(serializable & replayable)")

  Motivation_Driver(driver_research,  "Evolutionary Research\nPlatform")
  Motivation_Driver(driver_emergence, "Emergent Structure\nDiscovery")
  Motivation_Driver(driver_italian,   "Italian Stock Market\nOHLCV Data")
}

' ============================================================
' BUSINESS LAYER
' ============================================================

package "Business Layer" <<rectangle>> {

  Business_Process(proc_ingest,    "Market Data Ingestion\n(OHLCV Feed)")
  Business_Process(proc_evolution, "Evolutionary Process\n(Genome → FSM → Fitness)")
  Business_Process(proc_signal,    "Cooperative Signal\nGeneration")
  Business_Process(proc_persist,   "Ecosystem Memory\n(Event Sourcing)")
  Business_Process(proc_observe,   "Ecosystem Observation\n& Replay")

  Business_Service(svc_prediction,  "Prediction Service\n(daily investment signals)")
  Business_Service(svc_monitoring,  "Monitoring Service\n(real-time health)")
  Business_Service(svc_knowledge,   "Knowledge Service\n(archetype library)")

  Business_Object(bo_ohlcv,     "OHLCV Data\n(Italian Market)")
  Business_Object(bo_genome,    "Hybrid Graph Genome\n(L-System generated)")
  Business_Object(bo_archetype, "Archetype\n(proven FSM motif)")
  Business_Object(bo_niche,     "Market Niche\n(emergent cluster)")
  Business_Object(bo_signal,    "Investment Signal\n(daily output)")
}

' ============================================================
' APPLICATION LAYER — CORE INFRASTRUCTURE
' ============================================================

package "Application Layer — Core Infrastructure" <<rectangle>> {

  package "Core Infrastructure Node  [Raspberry Pi 1 · ARMv6l]" <<Node>> {
    Application_Component(ci_broker,    "NanoMQ Broker\nMQTT 3.1.1/5.0\nTCP:1883 · WS:8083")
    Application_Component(ci_scraper,   "borsa-italiana-scraper\nNode.js 14.15.1\nHTTPS → MQTT pub")
    Application_Component(ci_logger,    "Event Logger  [M2]\nRust · SQLite WAL\nappend-only")
    Application_Component(ci_persist,   "Persistence Service  [M2]\nRust · Parquet export\narchetype store")
    Application_Component(ci_cron,      "Cron Scheduler\nmarket-hours aware\n18:30 daily + 15min intraday")
    Application_Service(ci_svc,         "Core Infrastructure Service")
  }
}

' ============================================================
' APPLICATION LAYER — NODE TYPES
' ============================================================

package "Application Layer — Node Types" <<rectangle>> {

  package "Observatory Nodes  [Browser · Tablet · Smartphone]" <<Cloud>> {
    Application_Component(obs_deploymap,  "Deploy Architecture Map\n(node status · connectivity)")
    Application_Component(obs_theorymap,  "Theory Map\n(FSM motif browser · archetypes)")
    Application_Component(obs_galaxy,     "Evolution Galaxy  [3D]\n(clusters · species · niches)")
    Application_Component(obs_ecology,    "Signal Ecology View\n(cooperative signaling heatmap)")
    Application_Component(obs_market,     "Market Overlay\n(market events ↔ ecosystem)")
    Application_Component(obs_replay,     "Replay System\n(temporal · lineage · rewind)")
    Application_Component(obs_wasm,       "WASM FSM Replay\n(browser-side execution)")
    Application_Service(obs_svc,          "Observatory Service")
  }

  package "Evolution Nodes  [Linux PC · Android · MIMXRT1050]" <<Cloud>> {
    Application_Component(evo_mutation,   "Mutation Engine\n(structural · parametric · crossover)")
    Application_Component(evo_cluster,    "Clustering System\n(niche discovery · GA)")
    Application_Component(evo_niche,      "Niche Discovery\n(market regime classification)")
    Application_Component(evo_phenotype,  "Phenotype Analyzer\n(FSM runtime evaluation)")
    Application_Component(evo_mqtt,       "MQTT Client\n(tr4d3rz-messaging · Rust)")
    Application_Service(evo_svc,          "Evolution Service")
  }

  package "Optimization Nodes  [ESP8266 · STM32F107 · STM32F3]" <<Cloud>> {
    Application_Component(opt_tuning,     "Parameter Tuning\n(micro-optimization)")
    Application_Component(opt_validation, "Micro Validation\n(local fitness check)")
    Application_Component(opt_local,      "Local Optimizer\n(offline genome tuning)")
    Application_Component(opt_capsule,    "Capsule Manager\n(CBOR I/O · UART/USB)")
    Application_Service(opt_svc,          "Optimization Service")
  }

  package "Persistence Nodes  [Raspberry Pi 2 · PHP hosting]" <<Cloud>> {
    Application_Component(per_lineage,    "Lineage Storage\n(birth · death · mutation)")
    Application_Component(per_archetype,  "Archetype Memory\n(motif FSM · patterns · niches)")
    Application_Component(per_events,     "Event Logger\n(mutation · signal · migration)")
    Application_Component(per_relay,      "Relay Service\n(delayed sync · offline nodes)")
    Application_Service(per_svc,          "Persistence Service")
  }

  package "Gateway Nodes  [Linux · RPi]" <<Cloud>> {
    Application_Component(gw_uart,       "UART Bridge\n(serial framing · CBOR)")
    Application_Component(gw_protocol,   "Protocol Translator\n(UART/USB ↔ MQTT)")
    Application_Component(gw_delayed,    "Delayed Sync\n(capsule queue · offline)")
    Application_Service(gw_svc,          "Gateway Service")
  }
}

' ============================================================
' APPLICATION LAYER — CORE COMPONENTS
' ============================================================

package "Application Layer — Core Components" <<rectangle>> {

  package "Genome Pipeline  [tr4d3rz-core · Rust]" <<Frame>> {
    Application_Component(lsystem,       "L-System Generator\n(topology · modularity · recursion)")
    Application_Component(graph_exp,     "Graph Expansion\n(normalized graph)")
    Application_Component(fsm_gen,       "FSM Generator\n(state/transition table)")
    Application_Component(phenotype,     "Phenotype Runtime\n(executes FSM · emits signals)")
  }

  package "Condition Primitives  [tr4d3rz-core · Rust]" <<Frame>> {
    Application_Component(cond_ohlcv,    "OHLCV Primitives\n(open · high · low · close · volume)")
    Application_Component(cond_ind,      "Indicator Primitives\n(EMA · SMA · IIR · volatility · range)")
    Application_Component(cond_bucket,   "Bucketization Engine\n(LOW · NORMAL · HIGH · EXTREME)")
    Application_Component(cond_temporal, "Temporal Conditions\n(windows · sequences · delay)")
    Application_Component(cond_coop,     "Cooperative Conditions\n(inter-agent signals · events)")
  }

  package "Fitness System  [tr4d3rz-evolution · Rust]" <<Frame>> {
    Application_Component(fit_calc,      "Fitness Calculator\n(predictive_power + niche_strength\n+ cooperation_value + stat_confidence\n- computational_cost - signal_noise)")
    Application_Component(fit_niche,     "Niche Evaluator\n(niche consistency · specialization)")
    Application_Component(fit_coop,      "Cooperation Scorer\n(cooperation contribution)")
    Application_Component(fit_metrics,   "Base Metrics\n(trade_count · success_rate · CAGR\n· profit_factor)")
    Application_Component(fit_advanced,  "Advanced Metrics\n(signal_entropy · stat_confidence\n· computational_efficiency)")
  }

  package "Signaling System  [tr4d3rz-messaging]" <<Frame>> {
    Application_Component(sig_broker,    "Signal Broker\n(MQTT topic router)")
    Application_Component(sig_router,    "Event Router\n(QoS-aware dispatch)")
    Application_Component(sig_sub,       "Subscription Manager\n(topic filters · wildcards)")
  }

  package "Genome Capsule System  [tr4d3rz-embedded]" <<Frame>> {
    Application_Component(capsule_mgr,   "Genome Capsule Manager\n(task packages · compressed datasets\n· deferred results)")
    Application_Component(capsule_cbor,  "CBOR Serializer\n(embedded-safe · no_std)")
  }

  Application_Interface(mqtt_if,   "MQTT Interface\n(TCP:1883 · WS:8083)")
  Application_Interface(uart_if,   "UART/USB Interface\n(CBOR framing)")
  Application_Interface(rest_api,  "REST API\n(borsaitaliana.it · HTTPS)")
}

' ============================================================
' DATA OBJECTS
' ============================================================

package "Data Objects" <<rectangle>> {
  Business_Object(data_ohlcv,     "OHLCV Payload\n(JSON · ADR-0004 schema)")
  Business_Object(data_genome,    "Hybrid Graph Genome\n(CBOR · L-System generated)")
  Business_Object(data_fsm,       "FSM Definition\n(state · transition · condition)")
  Business_Object(data_signal,    "Cooperative Signal\n(CBOR · QoS 0 · agent_id)")
  Business_Object(data_fitness,   "Fitness Record\n(CBOR · QoS 1 · multi-dim)")
  Business_Object(data_event,     "System Event\n(CBOR · QoS 1 · append-only)")
  Business_Object(data_archetype, "Archetype\n(CBOR · QoS 2 · FSM motif)")
  Business_Object(data_capsule,   "Genome Capsule\n(CBOR file · offline sync)")
}

