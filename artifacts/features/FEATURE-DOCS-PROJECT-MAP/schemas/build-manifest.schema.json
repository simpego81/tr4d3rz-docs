{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simpego81.github.io/tr4d3rz-docs/schemas/project-map/build-manifest.schema.json",
  "title": "Build Manifest Schema",
  "description": "Metadata about dataset generation including version, timestamps, source hashes, errors, and warnings",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "generator_version",
    "git_commit",
    "sources",
    "datasets",
    "errors",
    "warnings",
    "last_valid_snapshot"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Version of this manifest schema"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when datasets were generated"
    },
    "generator_version": {
      "type": "string",
      "description": "Version of the build pipeline tool",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "examples": ["1.0.0"]
    },
    "git_commit": {
      "type": "string",
      "description": "Git commit hash of tr4d3rz-docs when build ran ('unknown' when git is unavailable)",
      "pattern": "^([a-f0-9]{7,40}|unknown)$"
    },
    "sources": {
      "type": "array",
      "description": "List of source files consumed with hashes",
      "items": {
        "type": "object",
        "required": ["path", "hash", "read_at"],
        "properties": {
          "path": {
            "type": "string",
            "description": "Repository-relative path",
            "examples": ["state/roadmap.yaml", "docs/archimate_data.json"]
          },
          "hash": {
            "type": "string",
            "description": "SHA-256 hash of file content",
            "pattern": "^[a-f0-9]{64}$"
          },
          "read_at": {
            "type": "string",
            "format": "date-time",
            "description": "When this file was read"
          },
          "status": {
            "type": "string",
            "enum": ["ok", "missing", "parse_error", "stale"],
            "description": "File status during build"
          }
        }
      },
      "minItems": 1
    },
    "datasets": {
      "type": "array",
      "description": "Generated dataset files with entity counts",
      "items": {
        "type": "object",
        "required": ["filename", "entity_count", "schema_version"],
        "properties": {
          "filename": {
            "type": "string",
            "examples": ["roadmap.json", "conceptual-map.json"]
          },
          "entity_count": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of entities in this dataset"
          },
          "schema_version": {
            "type": "string",
            "description": "Schema version this dataset conforms to"
          },
          "hash": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$",
            "description": "SHA-256 hash of generated dataset"
          }
        }
      }
    },
    "errors": {
      "type": "array",
      "description": "Critical errors that blocked full generation (MAP-E001 through MAP-E008)",
      "items": {
        "type": "object",
        "required": ["code", "message", "phase"],
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^MAP-E\\d{3}$",
            "examples": ["MAP-E001", "MAP-E002"]
          },
          "message": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1024
          },
          "phase": {
            "type": "string",
            "enum": ["collect", "normalize", "validate", "derive", "render", "publish"],
            "description": "Pipeline phase where error occurred"
          },
          "file": {
            "type": "string",
            "description": "File where error occurred (if applicable)"
          },
          "field": {
            "type": "string",
            "description": "Field/property where error occurred (if applicable)"
          },
          "line": {
            "type": "integer",
            "description": "Line number where error occurred (if applicable)",
            "minimum": 1
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "description": "Non-critical warnings (incomplete data, missing optional fields, staleness)",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^MAP-[EW]\\d{3}$",
            "description": "MAP-W codes for minor warnings, MAP-E codes for non-fatal anomalies that degrade data quality",
            "examples": ["MAP-W001", "MAP-W002", "MAP-E003", "MAP-E008"]
          },
          "message": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1024
          },
          "file": {
            "type": "string"
          }
        }
      }
    },
    "last_valid_snapshot": {
      "type": ["object", "null"],
      "description": "Reference to last successfully generated snapshot (for rollback)",
      "properties": {
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "git_commit": {
          "type": "string",
          "pattern": "^[a-f0-9]{7,40}$"
        },
        "path": {
          "type": "string",
          "description": "Path to archived snapshot directory"
        }
      }
    },
    "phase_durations": {
      "type": "object",
      "description": "Duration of each pipeline phase in milliseconds",
      "properties": {
        "collect": { "type": "number", "minimum": 0 },
        "normalize": { "type": "number", "minimum": 0 },
        "validate": { "type": "number", "minimum": 0 },
        "derive": { "type": "number", "minimum": 0 },
        "render": { "type": "number", "minimum": 0 },
        "publish": { "type": "number", "minimum": 0 },
        "total": { "type": "number", "minimum": 0 }
      }
    },
    "freshness_status": {
      "type": "string",
      "enum": ["FRESH", "STALE", "UNKNOWN"],
      "description": "Overall freshness assessment of datasets"
    }
  },
  "additionalProperties": false
}
